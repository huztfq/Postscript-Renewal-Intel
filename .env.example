# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Unipile — https://dashboard.unipile.com (DSN + access token + connected LinkedIn account id)
# Use UNIPILE_API_URL or UNIPILE_DSN (same value: your API host from the dashboard)
UNIPILE_API_URL=https://api1.unipile.com:13111
UNIPILE_ACCESS_TOKEN=your-unipile-access-token
UNIPILE_ACCOUNT_ID=your-linkedin-connected-account-id

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Tavily — https://tavily.com
TAVILY_API_KEY=your-tavily-api-key

# Inngest
# Local dev: set INNGEST_DEV=1 — SDK points to http://localhost:8288 (no key needed).
#            Run both services with: npm run dev:all
# Production: remove INNGEST_DEV (or set to 0) and fill in the keys below.
INNGEST_DEV=1
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
